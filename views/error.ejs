<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - OpenClaw Manager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>
  <div class="login-page">
    <div class="login-box" style="text-align:center;">
      <div style="font-size:56px;margin-bottom:16px;"><%= code === 404 ? '404' : 'Loi' %></div>
      <h2 style="margin-bottom:8px;font-weight:700;">Loi <%= code %></h2>
      <p style="color:var(--gray-500);margin-bottom:20px;"><%= message %></p>
      <a href="/" class="btn btn-primary">Ve trang chu</a>
    </div>
  </div>
</body>
</html>
