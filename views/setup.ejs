<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Thiet lap - OpenClaw Manager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
      -webkit-font-smoothing: antialiased;
    }
    .setup-box {
      background: #fff;
      border-radius: 16px;
      padding: 40px 36px;
      width: 440px;
      max-width: 92%;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .logo-area {
      text-align: center;
      margin-bottom: 8px;
    }
    .logo-icon {
      width: 52px; height: 52px;
      background: #22c55e;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 14px;
    }
    .logo-title {
      font-size: 24px;
      font-weight: 700;
      color: #111827;
      margin-bottom: 4px;
    }
    .logo-brand {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 24px;
    }
    .logo-brand strong {
      color: #22c55e;
      font-weight: 700;
    }
    .setup-subtitle {
      text-align: center;
      color: #6b7280;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 24px;
      padding-bottom: 20px;
      border-bottom: 1px solid #e5e7eb;
    }
    .form-group {
      margin-bottom: 18px;
    }
    .form-label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 6px;
    }
    .form-input {
      width: 100%;
      padding: 10px 14px;
      font-size: 14px;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      background: #fff;
      color: #1f2937;
      font-family: inherit;
      transition: all 0.15s;
      outline: none;
    }
    .form-input:focus {
      border-color: #22c55e;
      box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
    }
    .form-input::placeholder { color: #9ca3af; }
    .form-hint {
      font-size: 12px;
      color: #9ca3af;
      margin-top: 4px;
    }
    .btn-submit {
      width: 100%;
      padding: 12px;
      font-size: 15px;
      font-weight: 600;
      background: #22c55e;
      color: #fff;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.15s;
      margin-top: 4px;
    }
    .btn-submit:hover { background: #16a34a; }
    .btn-submit:active { transform: scale(0.98); }
    .alert-error {
      padding: 12px 14px;
      background: #fef2f2;
      color: #991b1b;
      border: 1px solid #fecaca;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .alert-icon {
      width: 20px; height: 20px;
      background: #ef4444;
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      flex-shrink: 0;
    }
  </style>
</head>
<body>
  <div class="setup-box">
    <div class="logo-area">
      <div class="logo-icon">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
          <path d="M8 16C8 11.58 11.58 8 16 8C20.42 8 24 11.58 24 16C24 20.42 20.42 24 16 24" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="16" cy="16" r="3" fill="white"/>
        </svg>
      </div>
      <div class="logo-title">OpenClaw Manager</div>
      <div class="logo-brand">Powered by <strong>GENCLOUD</strong> &mdash; Cloud VPS Hosting</div>
    </div>

    <div class="setup-subtitle">
      Tao tai khoan quan tri vien dau tien
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-error">
        <span class="alert-icon">!</span>
        <span><%= error %></span>
      </div>
    <% } %>

    <form method="POST" action="/auth/setup">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="form-group">
        <label class="form-label">Ten dang nhap</label>
        <input type="text" name="username" class="form-input" placeholder="admin" required autofocus autocomplete="username">
        <p class="form-hint">3-50 ky tu: chu cai, so, dau gach ngang</p>
      </div>

      <div class="form-group">
        <label class="form-label">Mat khau</label>
        <input type="password" name="password" class="form-input" placeholder="It nhat 8 ky tu" required minlength="8" autocomplete="new-password">
      </div>

      <div class="form-group">
        <label class="form-label">Xac nhan mat khau</label>
        <input type="password" name="confirmPassword" class="form-input" placeholder="Nhap lai mat khau" required autocomplete="new-password">
      </div>

      <button type="submit" class="btn-submit">Tao tai khoan</button>
    </form>
  </div>
</body>
</html>
