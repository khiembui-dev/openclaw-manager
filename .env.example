# =====================================================
# OpenClaw Manager - Environment Configuration
# =====================================================
# Copy this file to .env and update the values

# Server
PORT=3847
HOST=0.0.0.0
NODE_ENV=production

# Session secret (CHANGE THIS - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=change-this-to-a-random-string

# Encryption key for API keys at rest (CHANGE THIS - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=change-this-to-a-64-char-hex-string

# Database
DB_PATH=./data/manager.db

# Logging
LOG_DIR=./data/logs
LOG_LEVEL=info

# OpenClaw defaults
OPENCLAW_INSTALL_DIR=/opt/openclaw
OPENCLAW_CONFIG_DIR=/opt/openclaw/config
OPENCLAW_DATA_DIR=/opt/openclaw/data
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Manager
MANAGER_DIR=/opt/openclaw-manager
